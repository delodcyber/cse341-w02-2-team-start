{
  "swagger": "2.0",
  "info": {
    "title": "Temple API",
    "description": "API documentation for the Temple API",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/temples/": {
      "get": {
        "tags": [
          "Temples"
        ],
        "summary": "Get all temples",
        "description": "Returns all temples stored in the database.",
        "parameters": [
          {
            "name": "apiKey",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Temples"
        ],
        "summary": "Create a temple",
        "description": "Creates a new temple.",
        "parameters": [
          {
            "name": "apiKey",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "example": "any"
                },
                "temple_id": {
                  "example": "any"
                },
                "location": {
                  "example": "any"
                },
                "dedicated": {
                  "example": "any"
                },
                "additionalInfo": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/temples/{temple_id}": {
      "get": {
        "tags": [
          "Temples"
        ],
        "summary": "Get one temple",
        "description": "Returns a temple by its temple_id.",
        "parameters": [
          {
            "name": "temple_id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "apiKey",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "definitions": {
    "Temple": {
      "type": "object",
      "properties": {
        "temple_id": {
          "type": "number",
          "example": 1
        },
        "name": {
          "type": "string",
          "example": "Aba Nigeria Temple"
        },
        "location": {
          "type": "string",
          "example": "Aba, Nigeria"
        },
        "dedicated": {
          "type": "string",
          "example": "2005-08-07"
        },
        "additionalInfo": {
          "type": "boolean",
          "example": true
        }
      }
    }
  }
}